generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionCategory {
  SALARY
  FREELANCE
  INVESTMENT
  RENT
  UTILITIES
  GROCERIES
  DINING
  TRANSPORTATION
  HEALTHCARE
  ENTERTAINMENT
  SHOPPING
  EDUCATION
  SAVINGS
  INSURANCE
  DEBT_PAYMENT
  OTHER
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum RiskProfile {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
  VERY_AGGRESSIVE
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String?
  lastName        String?
  clerkId         String?   @unique
  avatarUrl       String?
  monthlyIncome   Float?    @default(0)
  riskProfile     RiskProfile? @default(MODERATE)
  onboardingComplete Boolean @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    Transaction[]
  budgets         Budget[]
  financialGoals  FinancialGoal[]
  investments     Investment[]
  debts           Debt[]
  learningProgress LearningProgress[]
  conversations   Conversation[]
  anomalies       Anomaly[]
  preferences     UserPreferences?
  agentHistory    ConversationHistory[]
  agentAnalytics  AgentAnalytics[]
  
  // Advanced Analytics
  portfolioAssets  PortfolioAsset[]
  taxOptimizations TaxOptimization[]
  opportunityScans OpportunityScan[]
  financialMetrics FinancialMetric[]
  
  // Recommendations
  dismissedRecommendations DismissedRecommendation[]
  pushSubscriptions        PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  keys      Json     // Contains p256dh and auth
  createdAt DateTime @default(now())

  @@index([userId])
}

model DismissedRecommendation {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendationId String   // Unique identifier for the specific recommendation logic
  dismissedAt      DateTime @default(now())
  expiresAt        DateTime // When the recommendation can be shown again (e.g., 30 days later)

  @@index([userId, recommendationId])
}

model PortfolioAsset {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetType      String   // "stocks", "bonds", "crypto", "cash", "gold"
  amount         Decimal
  percentage     Decimal  // 0-100
  purchasePrice  Decimal
  currentPrice   Decimal
  expectedReturn Decimal  // annual %
  riskLevel      String   // "low", "medium", "high"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, assetType])
  @@index([userId])
}

model TaxOptimization {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy         String   // "tax-loss-harvesting", "long-term-hold", etc
  savingsPotential Decimal  // TRY
  riskLevel        String   // "low", "medium", "high"
  description      String
  isApplied        Boolean  @default(false)
  appliedAt        DateTime?
  createdAt        DateTime @default(now())

  @@index([userId])
}

model OpportunityScan {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset               String   // "BIST100", "BTC", "ETH", "Gold", "USD/TRY"
  signal              String   // "BUY", "HOLD", "SELL"
  confidence          Decimal  // 0-1
  expectedReturn      Decimal  // % yearly
  riskScore           Decimal  // 0-10
  reason              String
  technicalIndicators String   // JSON of RSI, MACD, etc
  scanDate            DateTime @default(now())
  expiresAt           DateTime // signal valid until

  @@index([userId, scanDate])
}

model FinancialMetric {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricName   String   // "sharpe_ratio", "debt_to_income", "savings_rate"
  value        Decimal
  healthyMin   Decimal
  healthyMax   Decimal
  trend        String   // "improving", "declining", "stable"
  calculatedAt DateTime @default(now())

  @@unique([userId, metricName, calculatedAt])
  @@index([userId, metricName])
}

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique
  preferredAgent    String?
  favoriteAgents    Json     @default("[]")
  communicationStyle String  @default("detailed") // 'brief' | 'detailed' | 'technical'
  responseLanguage  String   @default("tr")       // 'tr' | 'en'
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConversationHistory {
  id            String   @id @default(cuid())
  userId        String
  agentId       String
  role          String   // 'user' | 'assistant' | 'agent' | 'system'
  content       String   @db.Text
  timestamp     DateTime @default(now())
  tokens        Int?
  metadata      Json?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentId])
  @@index([timestamp])
}

model AgentAnalytics {
  id              String   @id @default(cuid())
  userId          String
  agentId         String
  responseTime    Int      // in ms
  success         Boolean
  confidence      Float?
  error           String?  @db.Text
  interactionType String?  // 'chat' | 'tool_call'
  timestamp       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([timestamp])
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  type        TransactionType
  category    TransactionCategory
  amount      Float
  description String?
  date        DateTime          @default(now())
  isRecurring Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, category])
  @@index([userId, date])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  category  TransactionCategory
  amount    Float
  spent     Float    @default(0)
  month     Int
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
  @@index([userId, month, year])
}

model FinancialGoal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  targetAmount Float
  currentAmount Float    @default(0)
  deadline    DateTime?
  status      GoalStatus @default(ACTIVE)
  category    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model Investment {
  id          String       @id @default(cuid())
  userId      String
  name        String
  type        String
  amount      Float
  currentValue Float
  risk        RiskProfile  @default(MODERATE)
  notes       String?
  purchaseDate DateTime   @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Debt {
  id            String   @id @default(cuid())
  userId        String
  name          String
  totalAmount   Float
  remainingAmount Float
  interestRate  Float
  minimumPayment Float
  dueDate       Int?
  strategy      String?  @default("snowball")
  startDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LearningProgress {
  id        String   @id @default(cuid())
  userId    String
  topic     String
  completed Boolean  @default(false)
  score     Float?
  quizData  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, topic])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  messages  Json     @default("[]")
  agentType String?
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String   // "Budget", "Debt", "Investment", "Savings", "Retirement"
  embedding Unsupported("vector(384)")? // Gemini produces 384-dim vectors
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Anomaly {
  id             String   @id @default(cuid())
  userId         String
  type           String   // "spending_spike", "category_anomaly", "frequency_anomaly", "budget_breach"
  severity       Int      // 1-10
  message        String   @db.Text
  transactionId  String?
  reviewed       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

