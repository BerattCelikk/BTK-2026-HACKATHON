generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionCategory {
  SALARY
  FREELANCE
  INVESTMENT
  RENT
  UTILITIES
  GROCERIES
  DINING
  TRANSPORTATION
  HEALTHCARE
  ENTERTAINMENT
  SHOPPING
  EDUCATION
  SAVINGS
  INSURANCE
  DEBT_PAYMENT
  OTHER
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum RiskProfile {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
  VERY_AGGRESSIVE
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String?
  lastName        String?
  clerkId         String?   @unique
  avatarUrl       String?
  monthlyIncome   Float?    @default(0)
  riskProfile     RiskProfile? @default(MODERATE)
  onboardingComplete Boolean @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    Transaction[]
  budgets         Budget[]
  financialGoals  FinancialGoal[]
  investments     Investment[]
  debts           Debt[]
  learningProgress LearningProgress[]
  conversations   Conversation[]
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  type        TransactionType
  category    TransactionCategory
  amount      Float
  description String?
  date        DateTime          @default(now())
  isRecurring Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, category])
  @@index([userId, date])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  category  TransactionCategory
  amount    Float
  spent     Float    @default(0)
  month     Int
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
  @@index([userId, month, year])
}

model FinancialGoal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  targetAmount Float
  currentAmount Float    @default(0)
  deadline    DateTime?
  status      GoalStatus @default(ACTIVE)
  category    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model Investment {
  id          String       @id @default(cuid())
  userId      String
  name        String
  type        String
  amount      Float
  currentValue Float
  risk        RiskProfile  @default(MODERATE)
  notes       String?
  purchaseDate DateTime   @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Debt {
  id            String   @id @default(cuid())
  userId        String
  name          String
  totalAmount   Float
  remainingAmount Float
  interestRate  Float
  minimumPayment Float
  dueDate       Int?
  strategy      String?  @default("snowball")
  startDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LearningProgress {
  id        String   @id @default(cuid())
  userId    String
  topic     String
  completed Boolean  @default(false)
  score     Float?
  quizData  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, topic])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  messages  Json     @default("[]")
  agentType String?
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}
